# ─── Local Development ───────────────────────────────
# Copy this file to .env and fill in values if you need them.
#
# Hanzi Browse runs BYOM (bring your own model): the MCP/CLI and the
# Chrome extension read model credentials from your environment, your
# Claude Code / Codex login, the macOS Keychain, or the extension's
# settings. Nothing here is required to run locally.

# ─── Optional: model credentials ─────────────────────
# Any of these are auto-detected if present; you usually don't need to
# set them here.
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional: telemetry ─────────────────────────────

# Sentry (error tracking)
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# PostHog (product analytics)
# POSTHOG_API_KEY=phc_xxx
# POSTHOG_HOST=https://us.i.posthog.com
